# Leave empty in local development to use the Vite /api proxy.
VITE_API_BASE_URL=

# Public, read-only API key for Amazon Location Service Maps.
# Never put an IAM access key or secret access key in frontend code.
VITE_AWS_LOCATION_API_KEY=
VITE_AWS_LOCATION_REGION=ap-southeast-1
VITE_AWS_MAP_STYLE=Standard
VITE_AWS_MAP_COLOR_SCHEME=Light
