# Copy this file to .env on the EC2 server. Never commit .env.

# Docker image tag
APP_VERSION=latest

# PostgreSQL
DB_NAME=roamly
DB_USERNAME=roamly
DB_PASSWORD=replace-with-a-strong-database-password
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1

# Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password

# SMTP
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-app-password

# JWT: generate with `openssl rand -base64 64`
JWT_SECRET=replace-with-a-base64-encoded-secret

# Frontend origins, comma-separated. Leave empty until the frontend is deployed.
APP_CORS_ALLOWED_ORIGINS=

# Production diagnostics
SWAGGER_ENABLED=false
JPA_SHOW_SQL=false
ROOT_LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO
HIBERNATE_SQL_LOG_LEVEL=WARN

# JVM limit for a t3.small instance
JAVA_TOOL_OPTIONS=-Xms128m -Xmx512m -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError
